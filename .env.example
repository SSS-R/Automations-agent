# ==========================================================
# Auto-Clipper Environment Configuration
# ==========================================================
# IMPORTANT: Never commit your actual `.env` file to version control.
# Copy this file to `.env` and fill in your private keys.

# Google Gemini API Key
# Required for `highlighter.py` and `captioner.py` to analyze transcripts.
GOOGLE_API_KEY=your_gemini_api_key_here

# Redis Broker URL
# Required for Celery background processing queue. Defaults to local docker if unset.
REDIS_URL=redis://127.0.0.1:6379/0

# Note: In the future, platform-specific OAuth tokens (YouTube, TikTok) 
# will be placed here to prevent hardcoding secrets in the bot scripts.
